<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QualityScape | Lawn Care & Landscaping in Central Florida</title>
  <meta name="description" content="QualityScape provides honest lawn care, landscape details, and free estimates across Central Florida. Call or text 321-488-7188." />

  <!-- GitHub / Netlify ready: upload this file as index.html. No build step needed. -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --turf:#1f6e3c;
      --turf-dark:#123d22;
      --turf-soft:#e8f4e2;
      --leaf:#9bd77b;
      --sun:#f3b247;
      --soil:#2b2620;
      --muted:#66715f;
      --paper:#f5f7f2;
      --card:#ffffff;
      --line:#dce3d7;
      --shadow:0 20px 60px rgba(18,61,34,.15);
      --display:'Sora',system-ui,sans-serif;
      --body:'Public Sans',system-ui,sans-serif;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--body);color:var(--soil);background:var(--paper);line-height:1.6}
    img{max-width:100%;display:block}
    a{color:inherit}
    .container{width:min(1160px,calc(100% - 36px));margin:0 auto}
    .section{padding:84px 0}
    .section-title{font:800 clamp(2rem,4vw,3rem)/1.05 var(--display);letter-spacing:-.04em;color:var(--turf-dark);margin-bottom:14px}
    .section-copy{max-width:700px;color:var(--muted);font-size:1.04rem}
    .eyebrow{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border:1px solid rgba(31,110,60,.22);border-radius:999px;background:rgba(155,215,123,.18);color:var(--turf-dark);font:700 .76rem var(--display);letter-spacing:.08em;text-transform:uppercase}
    .eyebrow::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--leaf)}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:0;border-radius:999px;padding:14px 22px;background:var(--turf);color:#fff;text-decoration:none;font:800 .95rem var(--display);box-shadow:0 12px 28px rgba(31,110,60,.25);cursor:pointer}
    .btn:hover{background:#185a31;transform:translateY(-1px)}
    .btn.alt{background:#fff;color:var(--turf-dark);border:1px solid rgba(18,61,34,.14);box-shadow:none}
    .btn.light{background:var(--leaf);color:var(--turf-dark);box-shadow:none}
    .btn.full{width:100%}

    .topbar{background:var(--turf-dark);color:#eaf4e4;font-size:.9rem}
    .topbar .container{display:flex;justify-content:space-between;gap:18px;flex-wrap:wrap;padding:9px 0}
    .topbar a{text-decoration:none;color:#eaf4e4}
    .topbar a:hover{text-decoration:underline}

    .nav{position:sticky;top:0;z-index:1000;background:rgba(245,247,242,.92);backdrop-filter:blur(14px);border-bottom:1px solid rgba(220,227,215,.8)}
    .nav .container{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:16px 0}
    .brand{display:flex;align-items:center;gap:10px;text-decoration:none}
    .mark{width:44px;height:44px;border-radius:14px;background:linear-gradient(135deg,var(--turf),var(--leaf));display:grid;place-items:center;color:#fff;font:900 1.2rem var(--display);box-shadow:0 10px 24px rgba(31,110,60,.24)}
    .brand strong{font:800 1.2rem var(--display);letter-spacing:-.03em;color:var(--turf-dark)}
    .brand span{display:block;color:var(--muted);font-size:.78rem;margin-top:-2px}
    .nav-links{display:flex;align-items:center;gap:22px;font-weight:700;font-size:.92rem;color:#40503a}
    .nav-links a{text-decoration:none}
    .nav-links a:hover{color:var(--turf)}

    .hero{position:relative;overflow:hidden;padding:90px 0 68px;background:
      radial-gradient(circle at 12% 18%,rgba(155,215,123,.42),transparent 28%),
      linear-gradient(135deg,#f5f7f2 0%,#e7f2df 58%,#cfeac2 100%)}
    .hero::after{content:"";position:absolute;inset:auto -12% -44% 54%;height:620px;border-radius:50%;background:rgba(31,110,60,.12);filter:blur(8px)}
    .hero-grid{position:relative;z-index:1;display:grid;grid-template-columns:minmax(0,1.05fr) minmax(320px,.95fr);gap:44px;align-items:center}
    .hero h1{font:800 clamp(3rem,6vw,5.5rem)/.94 var(--display);letter-spacing:-.07em;color:var(--turf-dark);margin:18px 0}
    .hero p{font-size:1.13rem;color:#506048;max-width:620px}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:28px}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:34px;max-width:620px}
    .stat{background:rgba(255,255,255,.72);border:1px solid rgba(255,255,255,.9);border-radius:20px;padding:16px;box-shadow:0 16px 40px rgba(18,61,34,.08)}
    .stat strong{display:block;font:800 1.55rem var(--display);color:var(--turf-dark)}
    .stat span{font-size:.85rem;color:var(--muted);font-weight:700}
    .hero-card{border-radius:34px;overflow:hidden;background:#fff;box-shadow:var(--shadow);position:relative;border:8px solid rgba(255,255,255,.7)}
    .hero-card img{width:100%;height:520px;object-fit:cover}
    .rating-card{position:absolute;left:18px;bottom:18px;right:18px;background:rgba(255,255,255,.94);border-radius:22px;padding:16px;display:flex;align-items:center;gap:14px;box-shadow:0 16px 34px rgba(0,0,0,.14)}
    .rating-card img{width:132px;height:auto;object-fit:contain;border-radius:0}
    .rating-card strong{font:800 1rem var(--display);color:var(--turf-dark);display:block}
    .rating-card span{font-size:.86rem;color:var(--muted)}

    .quick-contact{margin-top:-34px;position:relative;z-index:5}
    .quick-contact .container{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .contact-pill{background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);border-radius:22px;padding:20px;text-decoration:none;display:flex;gap:14px;align-items:flex-start}
    .contact-pill .icon{width:42px;height:42px;border-radius:14px;background:var(--turf-soft);display:grid;place-items:center;color:var(--turf);font-weight:900}
    .contact-pill strong{display:block;font:800 .96rem var(--display);color:var(--turf-dark)}
    .contact-pill span{display:block;color:var(--muted);font-size:.92rem;margin-top:2px}

    .services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:34px}
    .service-card{background:var(--card);border:1px solid var(--line);border-radius:28px;padding:26px;box-shadow:0 14px 38px rgba(18,61,34,.06)}
    .service-card .num{font:900 .78rem var(--display);color:var(--turf);letter-spacing:.1em}
    .service-card h3{font:800 1.35rem/1.15 var(--display);letter-spacing:-.03em;color:var(--turf-dark);margin:10px 0}
    .service-card p{color:var(--muted);font-size:.96rem}
    .service-card ul{list-style:none;margin-top:18px;display:grid;gap:9px;color:#4a5744;font-size:.94rem;font-weight:600}
    .service-card li{display:flex;gap:9px;align-items:flex-start}
    .service-card li::before{content:"✓";color:var(--turf);font-weight:900}

    .split{display:grid;grid-template-columns:.95fr 1.05fr;gap:34px;align-items:center}
    .image-stack{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .image-stack img{height:255px;width:100%;object-fit:cover;border-radius:24px;box-shadow:0 12px 30px rgba(18,61,34,.12)}
    .image-stack img:first-child{grid-column:1/3;height:330px}
    .feature-list{display:grid;gap:14px;margin:26px 0}
    .feature{display:flex;gap:14px;background:#fff;border:1px solid var(--line);border-radius:18px;padding:16px}
    .feature b{width:34px;height:34px;border-radius:12px;background:var(--turf-soft);display:grid;place-items:center;color:var(--turf);flex-shrink:0}
    .feature strong{display:block;font:800 .98rem var(--display);color:var(--turf-dark)}
    .feature span{color:var(--muted);font-size:.92rem}

    .estimate-section{background:linear-gradient(180deg,#123d22 0%,#1f6e3c 100%);color:#fff;overflow:hidden}
    .estimate-section .section-title{color:#fff}
    .estimate-section .section-copy{color:#dcefd3}
    .estimate-shell{margin-top:34px;background:var(--paper);color:var(--soil);border-radius:30px;overflow:hidden;box-shadow:0 28px 70px rgba(0,0,0,.22);border:1px solid rgba(255,255,255,.14)}
    header.widget-head{padding:16px 24px 12px;border-bottom:1px solid var(--line);background:var(--card);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
    header.widget-head h3{font-family:var(--display);font-weight:800;font-size:1.25rem;color:var(--turf-dark);letter-spacing:-.02em}
    header.widget-head p{font-size:.85rem;color:#5a6355;margin-top:2px}
    .head-phone{font:800 .9rem var(--display);color:var(--turf);text-decoration:none;white-space:nowrap}
    .head-phone:hover{text-decoration:underline}
    .layout{display:flex;min-height:620px}
    .map-wrap{flex:1;position:relative;min-height:520px}
    #map{position:absolute;inset:0;cursor:crosshair;z-index:1}
    #map.browsing{cursor:grab}
    .searchbar{position:absolute;top:14px;left:50%;transform:translateX(-50%);z-index:900;display:flex;gap:8px;width:min(480px,calc(100% - 28px))}
    .searchbar input{flex:1;padding:11px 14px;border:1px solid var(--line);border-radius:10px;font:600 .95rem var(--body);background:var(--card);box-shadow:0 4px 14px rgba(18,61,34,.18)}
    .searchbar input:focus{outline:2px solid var(--turf);outline-offset:1px}
    .searchbar button{padding:11px 18px;border:0;border-radius:10px;background:var(--turf);color:#fff;font:800 .95rem var(--display);cursor:pointer;box-shadow:0 4px 14px rgba(18,61,34,.18)}
    .searchbar button:hover{background:#185a31}
    .map-hint{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);z-index:900;background:rgba(18,61,34,.92);color:#eaf4e4;padding:9px 16px;border-radius:999px;font-size:.85rem;font-weight:600;pointer-events:none;white-space:nowrap;max-width:calc(100% - 28px);overflow:hidden;text-overflow:ellipsis}
    aside.panel{width:360px;flex-shrink:0;background:var(--card);border-left:1px solid var(--line);display:flex;flex-direction:column;overflow-y:auto}
    .steps{padding:18px 20px 6px;display:flex;flex-direction:column;gap:14px}
    .step{display:flex;gap:12px;align-items:flex-start;opacity:.45;transition:opacity .25s}
    .step.active,.step.done{opacity:1}
    .step .dot{width:26px;height:26px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;font:800 .8rem var(--display);border:2px solid var(--turf);color:var(--turf)}
    .step.done .dot{background:var(--turf);color:#fff}
    .step h3{font:800 .92rem var(--display);color:var(--turf-dark)}
    .step p{font-size:.82rem;color:#5a6355;margin-top:2px;line-height:1.45}
    .draw-actions{display:flex;gap:8px;padding:12px 20px 0;flex-wrap:wrap}
    .draw-actions button{padding:8px 13px;border-radius:8px;font:800 .82rem var(--body);cursor:pointer;border:1px solid var(--line);background:var(--paper);color:var(--soil)}
    .draw-actions button.primary{background:var(--turf);border-color:var(--turf);color:#fff}
    .draw-actions button:hover{filter:brightness(.96)}
    .draw-actions button:disabled{opacity:.4;cursor:not-allowed}
    .ticket{margin:18px 20px 14px;background:var(--turf-dark);border-radius:14px;color:#eaf4e4;padding:20px;position:relative;overflow:hidden}
    .ticket::after{content:"";position:absolute;inset:0;pointer-events:none;opacity:.07;background:repeating-linear-gradient(105deg,#fff 0 18px,transparent 18px 36px)}
    .ticket .label{font:800 .72rem var(--display);letter-spacing:.12em;text-transform:uppercase;color:var(--leaf)}
    .ticket .sqft{font:800 2.4rem/1.1 var(--display);letter-spacing:-.02em;margin:6px 0 2px;color:#fff;font-variant-numeric:tabular-nums}
    .ticket .sqft small{font:700 1rem var(--display);color:var(--leaf)}
    .ticket .sections{font-size:.8rem;color:#b8cdb0;margin-bottom:14px}
    .band-track{display:flex;gap:4px;margin:10px 0 6px;position:relative;z-index:1}
    .band-track span{flex:1;height:8px;border-radius:4px;background:rgba(255,255,255,.16);transition:background .3s}
    .band-track span.lit{background:var(--leaf)}
    .band-names{display:flex;font-size:.62rem;color:#8faf87;letter-spacing:.04em;text-transform:uppercase}
    .band-names span{flex:1;text-align:center}
    .price{margin-top:16px;padding-top:14px;border-top:1px dashed rgba(255,255,255,.25);position:relative;z-index:1}
    .price .amount{font:800 1.7rem var(--display);color:#fff}
    .price .per,.price .service{font-size:.85rem;color:#b8cdb0}
    .cta{display:block;text-align:center;margin-top:14px;padding:12px;border-radius:10px;background:var(--leaf);color:var(--turf-dark);font:800 .95rem var(--display);text-decoration:none;position:relative;z-index:1}
    .cta:hover{filter:brightness(1.05)}
    .cta.secondary{background:transparent;border:1.5px solid var(--leaf);color:var(--leaf);margin-top:8px}
    .fineprint{padding:0 20px 20px;font-size:.72rem;color:#8a9484;line-height:1.5}
    .leaflet-container{font-family:var(--body)}
    .vertex-icon{background:transparent;border:0}

    .pricing{background:#fff}
    .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:34px}
    .price-card{border:1px solid var(--line);border-radius:28px;padding:28px;background:linear-gradient(180deg,#fff,#f8fbf5);box-shadow:0 14px 38px rgba(18,61,34,.06);position:relative;overflow:hidden}
    .price-card.featured{border-color:rgba(31,110,60,.42);box-shadow:0 20px 54px rgba(31,110,60,.16)}
    .price-card h3{font:800 1.35rem var(--display);color:var(--turf-dark);letter-spacing:-.03em}
    .price-card .amount{font:800 2.3rem var(--display);color:var(--turf);margin:14px 0 3px}
    .price-card .amount span{font-size:1rem;color:var(--muted)}
    .price-card p{color:var(--muted)}
    .price-card ul{list-style:none;margin:22px 0;display:grid;gap:10px;font-weight:600;color:#465240}
    .price-card li{display:flex;gap:9px}
    .price-card li::before{content:"✓";color:var(--turf);font-weight:900}

    .gallery-grid{display:grid;grid-template-columns:1.2fr .8fr .8fr;gap:14px;margin-top:34px}
    .gallery-grid img{height:280px;width:100%;object-fit:cover;border-radius:24px;box-shadow:0 12px 30px rgba(18,61,34,.1)}
    .gallery-grid img:first-child{height:574px;grid-row:span 2}

    .quote{background:linear-gradient(135deg,#e8f4e2,#f5f7f2)}
    .quote-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:34px;align-items:start}
    .quote-card{background:#fff;border:1px solid var(--line);border-radius:30px;padding:28px;box-shadow:var(--shadow)}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .field{display:flex;flex-direction:column;gap:7px}
    .field.full{grid-column:1/3}
    label{font-weight:800;color:var(--turf-dark);font-size:.9rem}
    input,select,textarea{width:100%;border:1px solid var(--line);border-radius:14px;padding:13px 14px;font:500 .98rem var(--body);background:#fbfcfa;color:var(--soil)}
    textarea{min-height:126px;resize:vertical}
    input:focus,select:focus,textarea:focus{outline:2px solid rgba(31,110,60,.35);border-color:var(--turf)}
    .small-note{font-size:.8rem;color:var(--muted);margin-top:10px}
    .footer{background:var(--turf-dark);color:#dcefd3;padding:52px 0 24px}
    .footer-grid{display:grid;grid-template-columns:1.2fr .8fr .8fr;gap:26px;margin-bottom:34px}
    .footer h3,.footer h4{font-family:var(--display);color:#fff;margin-bottom:10px}
    .footer p,.footer a{color:#dcefd3;text-decoration:none}
    .footer a:hover{text-decoration:underline}
    .copyright{border-top:1px solid rgba(255,255,255,.12);padding-top:20px;color:#b8cdb0;font-size:.88rem}

    @media (max-width:920px){
      .hero-grid,.split,.quote-grid{grid-template-columns:1fr}
      .quick-contact .container,.services-grid,.pricing-grid,.footer-grid{grid-template-columns:1fr}
      .layout{flex-direction:column}
      aside.panel{width:100%;border-left:0;border-top:1px solid var(--line)}
      .map-wrap{min-height:58vh}
      .gallery-grid{grid-template-columns:1fr 1fr}
      .gallery-grid img:first-child{grid-column:1/3;height:360px}
      .nav-links{display:none}
    }
    @media (max-width:620px){
      .section{padding:58px 0}
      .hero{padding:64px 0 58px}
      .stats,.form-grid,.gallery-grid{grid-template-columns:1fr}
      .field.full,.gallery-grid img:first-child{grid-column:auto}
      .hero-card img,.gallery-grid img,.gallery-grid img:first-child{height:310px}
      .quick-contact{margin-top:0;padding-top:18px;background:var(--paper)}
      .topbar .container{display:block}
      .rating-card{position:static;border-radius:0}
    }
    @media (prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important;scroll-behavior:auto!important}}
  </style>
</head>
