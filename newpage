  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script>
    document.getElementById('year').textContent = new Date().getFullYear();

    /* ================================================================
       QUALITYSCAPE INSTANT ESTIMATE CONFIG
       The $30 Small price matches the live pricing page. Confirm the
       other estimate bands with the owner before launching publicly.
    ================================================================ */
    const PRICING = {
      service: "Basic lawn care",
      per: "per cut",
      ctaHref: "#quote",
      bands: [
        { name: "Small",   maxSqFt: 5000,    price: 30 },
        { name: "Medium",  maxSqFt: 10000,   price: 40 },
        { name: "Large",   maxSqFt: 20000,   price: 55 },
        { name: "XL",      maxSqFt: 43560,   price: 75 },
        { name: "Estate",  maxSqFt: Infinity, price: null }
      ],
      customQuoteLabel: "Custom quote",
      ctaCustomHref: "#quote"
    };

    const START_VIEW = { lat: 28.52, lng: -81.05, zoom: 10 };
    const map = L.map('map', { doubleClickZoom: true }).setView([START_VIEW.lat, START_VIEW.lng], START_VIEW.zoom);

    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      maxZoom: 20,
      maxNativeZoom: 19,
      attribution: 'Imagery &copy; Esri &amp; contributors'
    }).addTo(map);

    let drawing = false;
    let currentPts = [];
    let currentLayer = null;
    let vertexMarkers = [];
    const sections = [];

    const $ = id => document.getElementById(id);
    const hint = $('hint');

    function geodesicAreaSqFt(latLngs){
      const R = 6378137, rad = Math.PI/180;
      let area = 0, n = latLngs.length;
      if (n < 3) return 0;
      for (let i = 0; i < n; i++){
        const p1 = latLngs[i], p2 = latLngs[(i+1)%n];
        area += (p2.lng - p1.lng)*rad * (2 + Math.sin(p1.lat*rad) + Math.sin(p2.lat*rad));
      }
      return Math.abs(area * R * R / 2) * 10.7639;
    }

    const bandTrack = $('bandTrack'), bandNames = $('bandNames');
    PRICING.bands.forEach(b => {
      bandTrack.appendChild(document.createElement('span'));
      const n = document.createElement('span');
      n.textContent = b.name;
      bandNames.appendChild(n);
    });

    function bandIndex(sqft){
      return PRICING.bands.findIndex(b => sqft <= b.maxSqFt);
    }

    function updateTicket(){
      const inProgress = drawing && currentPts.length >= 3 ? geodesicAreaSqFt(currentPts) : 0;
      const total = sections.reduce((s, x) => s + x.areaSqFt, 0) + inProgress;
      const sqft = Math.round(total);

      $('sqft').textContent = sqft.toLocaleString();
      $('sectionCount').textContent = sections.length === 0
        ? (drawing ? 'Tracing first section…' : 'No sections traced yet')
        : sections.length + ' section' + (sections.length > 1 ? 's' : '') + ' traced' + (drawing ? ' + 1 in progress' : '');

      const idx = sqft > 0 ? bandIndex(sqft) : -1;
      [...bandTrack.children].forEach((el, i) => el.classList.toggle('lit', i <= idx && idx >= 0));

      const cta = $('ctaLink');
      if (sqft === 0){
        $('priceAmount').textContent = '—';
        $('pricePer').textContent = '';
        $('serviceName').textContent = '';
        cta.href = PRICING.ctaHref;
        cta.textContent = 'Lock in this price';
      } else {
        const band = PRICING.bands[idx];
        if (band.price === null){
          $('priceAmount').textContent = PRICING.customQuoteLabel;
          $('pricePer').textContent = 'we will come take a look — free';
          cta.href = PRICING.ctaCustomHref;
          cta.textContent = 'Request a free quote';
        } else {
          $('priceAmount').textContent = 'Starting at $' + band.price;
          $('pricePer').textContent = PRICING.per;
          cta.href = PRICING.ctaHref;
          cta.textContent = 'Lock in this price';
        }
        $('serviceName').textContent = PRICING.service + ' · ' + band.name + ' lawn';
      }

      $('step3').classList.toggle('done', sqft > 0);
    }

    const lawnStyle = { color:'#9bd77b', weight:2.5, fillColor:'#2e9e52', fillOpacity:.35 };

    function vertexIcon(){
      return L.divIcon({
        className:'vertex-icon',
        iconSize:[12,12],
        html:'<div style="width:12px;height:12px;border-radius:50%;background:#9bd77b;border:2px solid #123d22"></div>'
      });
    }

    function redrawCurrent(){
      if (currentLayer){ map.removeLayer(currentLayer); currentLayer = null; }
      if (currentPts.length === 0) return;
      currentLayer = currentPts.length >= 3
        ? L.polygon(currentPts, lawnStyle).addTo(map)
        : L.polyline(currentPts, { color:'#9bd77b', weight:2.5, dashArray:'6 6' }).addTo(map);
    }

    function setDrawing(on){
      drawing = on;
      map.doubleClickZoom[on ? 'disable' : 'enable']();
      $('map').classList.toggle('browsing', !on);
      $('startBtn').textContent = on ? 'Add another section' : (sections.length ? 'Add another section' : 'Start tracing');
      $('startBtn').disabled = on;
      $('finishBtn').disabled = !on;
      $('undoBtn').disabled = !on;
      $('clearBtn').disabled = sections.length === 0 && !on;
      $('step1').classList.add('done');
      $('step1').classList.remove('active');
      $('step2').classList.toggle('active', on);
      hint.textContent = on
        ? 'Click each corner of the grass · double-click to finish'
        : (sections.length ? 'Add another section, or lock in your price below' : 'Press “Start tracing”, then click your lawn’s corners');
      setTimeout(() => map.invalidateSize(), 50);
    }

    map.on('click', e => {
      if (!drawing) return;
      currentPts.push(e.latlng);
      const m = L.marker(e.latlng, { icon: vertexIcon(), interactive:false }).addTo(map);
      vertexMarkers.push(m);
      redrawCurrent();
      updateTicket();
    });

    map.on('dblclick', () => { if (drawing) finishSection(); });

    function finishSection(){
      if (currentPts.length < 3){
        hint.textContent = 'Click at least 3 corners to make a shape';
        return;
      }
      const areaSqFt = geodesicAreaSqFt(currentPts);
      if (currentLayer) map.removeLayer(currentLayer);
      const layer = L.polygon(currentPts, lawnStyle).addTo(map);
      sections.push({ layer, areaSqFt });
      vertexMarkers.forEach(m => map.removeLayer(m));
      vertexMarkers = [];
      currentPts = [];
      currentLayer = null;
      setDrawing(false);
      updateTicket();
    }

    $('startBtn').addEventListener('click', () => {
      if (map.getZoom() < 17){
        hint.textContent = 'Zoom in closer to your yard first (search your address above)';
        return;
      }
      setDrawing(true);
      updateTicket();
    });

    $('finishBtn').addEventListener('click', finishSection);
    $('undoBtn').addEventListener('click', () => {
      currentPts.pop();
      const m = vertexMarkers.pop();
      if (m) map.removeLayer(m);
      redrawCurrent();
      updateTicket();
    });
    $('clearBtn').addEventListener('click', () => {
      sections.forEach(s => map.removeLayer(s.layer));
      sections.length = 0;
      vertexMarkers.forEach(m => map.removeLayer(m));
      vertexMarkers = [];
      currentPts = [];
      if (currentLayer) map.removeLayer(currentLayer);
      currentLayer = null;
      setDrawing(false);
      updateTicket();
    });

    async function search(){
      const q = $('addr').value.trim();
      if (!q) return;
      hint.textContent = 'Searching…';
      try{
        const res = await fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(q));
        const data = await res.json();
        if (data && data.length){
          map.setView([+data[0].lat, +data[0].lon], 19);
          setTimeout(() => map.invalidateSize(), 120);
          hint.textContent = 'Found it — press “Start tracing” and click your lawn’s corners';
          $('step1').classList.add('done');
          $('step2').classList.add('active');
        } else {
          hint.textContent = 'Address not found — try adding city and state, or pan the map by hand';
        }
      } catch {
        hint.textContent = 'Search unavailable right now — pan and zoom to your home instead';
      }
    }

    $('searchBtn').addEventListener('click', search);
    $('addr').addEventListener('keydown', e => { if (e.key === 'Enter') search(); });

    document.querySelectorAll('a[href="#estimate"]').forEach(link => {
      link.addEventListener('click', () => setTimeout(() => map.invalidateSize(), 500));
    });

    updateTicket();
  </script>
